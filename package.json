{
  "name": "storefront-backend-app",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "npm run build && tsx src/server.ts",
    "build": "tsc",
    "dev": "npm run build && nodemon --watch src --ext ts --exec tsx src/server.ts",
    "test": " npm run build && cross-env NODE_ENV=test jasmine-ts",
    "migrate:up_dev": "db-migrate up -e dev",
    "migrate:up_test": "db-migrate up -e test",
    "migrate:down_dev": "db-migrate down -c=5 -e dev",
    "migrate:down_test": "db-migrate down -c=5 -e test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "gitignore": "^0.7.0",
    "jasmine": "^3.99.0",
    "jasmine-spec-reporter": "^7.0.0",
    "jasmine-ts": "^0.4.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
