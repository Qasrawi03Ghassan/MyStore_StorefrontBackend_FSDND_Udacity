{
  "name": "storefront-backend-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "npm run build && tsx src/server.ts",
    "build": "tsc",
    "dev": "npm run build && nodemon --watch src --ext ts --exec tsx src/server.ts",
    "test": "npm run build && jasmine-ts",
    "migrate:up_dev": "db-migrate up -e dev",
    "migrate:up_test": "db-migrate up -e test",
    "migrate:down_dev": "db-migrate down -c=3 -e dev",
    "migrate:down_test": "db-migrate down -c=3 -e test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "gitignore": "^0.7.0",
    "jasmine": "^3.99.0",
    "jasmine-spec-reporter": "^7.0.0",
    "jasmine-ts": "^0.4.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
